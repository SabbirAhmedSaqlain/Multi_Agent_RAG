# ════════════════════════════════════════════════════════════════
#  Multi-Agent RAG configuration — copy to .env and edit
# ════════════════════════════════════════════════════════════════

# ── LLM provider: anthropic | ollama | lmstudio | openai ─────────
LLM_PROVIDER=anthropic

# Option A — Anthropic Claude (best quality)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Option B — Ollama (free, local, open-source models)
#   install: https://ollama.com   then: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Option C — LM Studio (free, local, GUI)
#   install: https://lmstudio.ai  → load a model → enable Local Server
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=            # empty = auto-detect the loaded model

# Option D — Any OpenAI-compatible endpoint (vLLM, llama.cpp, Groq, Together...)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── LLM behaviour ────────────────────────────────────────────────
MAX_TOKENS=8192
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=300
LLM_MAX_RETRIES=3
MAX_REVISION_CYCLES=2

# ── Retrieval ────────────────────────────────────────────────────
VECTOR_BACKEND=faiss        # faiss | chroma | numpy
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=600
CHUNK_OVERLAP=80
TOP_K_RETRIEVE=8
TOP_K_FINAL=5
SCORE_THRESHOLD=0.25

# ── Open-source dataset ingestion ────────────────────────────────
DATASET_NAME=wikipedia-simple
DATASET_MAX_DOCS=500

# ── API server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Used by scripts/update_data.sh to hot-swap a running API's index
#RAG_API_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
